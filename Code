import numpy as np
# 1. Tokenization
sentence = "Prompt engineering is intresting"
tokens = sentence.split()
print("Tokens:", tokens)

# 2. Embedding Matrix
embedding_dim = 4
np.random.seed(13)  # reproducibility
embedding_matrix = {token: np.random.rand(embedding_dim) for token in tokens}

print("\nEmbedding Matrix:")
for token, vector in embedding_matrix.items():
    print(token, ":", vector)

# 3. Dot Product with Scaling
# Example vectors (could be embeddings)
a = np.array([1, 2, 3])
b = np.array([4, 5, 6])
# Dot product
dot_product = np.dot(a, b)

# Scale by vector magnitudes (cosine similarity style)
scale = (np.linalg.norm(a) * np.linalg.norm(b))
scaled_dot = dot_product / scale

print("\nVector a:", a)
print("Vector b:", b)
print("Dot Product:", dot_product)
print("Scaled Dot Product (cosine similarity):", scaled_dot)
